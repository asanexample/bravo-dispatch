# Keep the build context minimal. The tracker and notify builds need their own source (web/, services/notify/),
# built inside the image, but never the host's node_modules or a stale dist — those are produced fresh in each
# service's own build stage.
.git
.github
k8s
*.md
catalog-info.yaml
.dockerignore
web/node_modules
web/dist
services/notify/node_modules
services/notify/dist
